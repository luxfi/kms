# Lux KMS Backend Environment Variables
# Copy to .env and populate from KMS: kms.hanzo.ai

# Get from KMS: kms.hanzo.ai/lux/kms/database-url
DATABASE_URL=<from-kms>
# Get from KMS: kms.hanzo.ai/lux/kms/encryption-key
ENCRYPTION_KEY=<from-kms>
# Get from KMS: kms.hanzo.ai/lux/kms/auth-secret
AUTH_SECRET=<from-kms>

PORT=8071
